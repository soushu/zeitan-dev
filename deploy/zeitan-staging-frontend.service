[Unit]
Description=Zeitan Staging Frontend (Next.js)
After=network.target zeitan-staging-backend.service

[Service]
User=yutookiguchi
WorkingDirectory=/home/yutookiguchi/zeitan-dev-staging/frontend
ExecStart=/usr/bin/node /home/yutookiguchi/zeitan-dev-staging/frontend/node_modules/.bin/next start -p 3004
EnvironmentFile=/home/yutookiguchi/zeitan-dev-staging/frontend/.env.local
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
